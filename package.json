{
  "name": "@phrase/phrase-mcp-server",
  "version": "0.10.0",
  "description": "MCP server for Phrase localization API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "phrase-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "imports": {
    "#package.json": "./package.json",
    "#*": {
      "types": "./src/*",
      "default": "./dist/*"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "form-data": "^3.0.4",
    "node-fetch": "^2.7.0",
    "phrase-js": "^3.23.0",
    "zod": "^3.24.2"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phrase/phrase-mcp-server.git"
  }
}
